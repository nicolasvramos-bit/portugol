programa {
  funcao inicio() { 
    inteiro idade

    escreva("Informe sua idade: ")
    leia(idade)
     // fazer idade maior ou igual a 16
    se(idade >=16){
      escreva("Você pode entrar!")
    }
    senao//tentei fazer valer a pena
    {
      escreva("Você não pode entrar!")
    }
    }
  }

